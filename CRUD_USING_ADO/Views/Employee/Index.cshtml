@model List<CRUD_USING_ADO.Models.Employee>

<h2>Employee List</h2>

<a asp-action="Create" class="btn btn-primary">Add New</a>

<table border="1" class="table">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Age</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Empid</td>
            <td>@item.EmpName</td>
            <td>@item.Email</td>
            <td>@item.Age</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Empid">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Empid"
                   onclick="return confirm('Are you sure?')">Delete</a>
            </td>
        </tr>
    }
</table>